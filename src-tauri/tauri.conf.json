{
    "productName": "tixup",
    "version": "0.1.0",
    "identifier": "com.tixup.app",
    "build": {
        "frontendDist": "../dist",
        "devUrl": null,
        "beforeDevCommand": "",
        "beforeBuildCommand": ""
    },
    "app": {
        "windows": [
            {
                "title": "Tixup",
                "width": 1280,
                "height": 800
            }
        ],
        "security": {
            "csp": "default-src 'self'; img-src 'self' https://* asset:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net;"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}